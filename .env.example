# =============================================================================
# Friends AI — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values. Never commit .env to git.

# --- AI Provider Keys ---
GOOGLE_GENERATIVE_AI_API_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=

# --- OAuth Credentials ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_ID=
GITHUB_SECRET=

# --- Auth ---
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Database ---
MONGODB_URI=

# --- Payment Gateway (Razorpay) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# --- Email (Resend) ---
RESEND_API_KEY=

# --- Background Jobs (Valkey/Redis) ---
VALKEY_URL=

# --- Object Storage (R2/S3) ---
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

# --- Webhooks ---
MEDIA_WEBHOOK_SECRET=
ENTITLEMENT_JWT_SECRET=

# --- External Trend APIs ---
NEWSAPI_KEY=
YOUTUBE_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Observability (Optional) ---
LANGSMITH_API_KEY=

# LangSmith Observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT="friends-ai-production"
LANGCHAIN_API_KEY=

# Internal Worker Authentication (For Media Webhooks)
INTERNAL_WORKER_SECRET=your_generated_secret_key
