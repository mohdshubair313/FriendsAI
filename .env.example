# =============================================================================
# Friends AI — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values. Never commit .env to git.

# --- Chat (LLM) Provider ---
# OpenRouter is the only required chat provider. Free models are used by
# default — see src/services/providers/registry.ts for the model list.
OPENROUTER_API_KEY=

# Optional fallback / multimodal providers — leave blank if not using.
GOOGLE_GENERATIVE_AI_API_KEY=
NVIDIA_API_KEY=

# --- Image Generation (Cloudflare Workers AI) ---
# Free tier: 10,000 Neurons/day = ~2,000 images/day with flux-1-schnell.
# Get these from https://dash.cloudflare.com/?to=/:account/workers-ai
CLOUDFLARE_ACCOUNT_ID=2b1c2de68059d3a647712c6b81768be2
CLOUDFLARE_API_TOKEN=

# --- Image Hosting (Cloudinary) ---
# Free tier: 25 GB storage + 25 GB bandwidth/month.
# Get these from https://console.cloudinary.com/console/c-<your-cloud>/settings/api-keys
CLOUDINARY_CLOUD_NAME=friendsAI_Image_storage
CLOUDINARY_API_KEY=544246916682269
CLOUDINARY_API_SECRET=7FuwXtkp8hLbKlssPoBqEGzKzLI

# --- OAuth Credentials ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_ID=
GITHUB_SECRET=

# --- Auth ---
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Database ---
MONGODB_URI=

# --- Payment Gateway (Razorpay) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# --- Email (Resend) ---
RESEND_API_KEY=

# --- Webhooks ---
ENTITLEMENT_JWT_SECRET=

# --- External Trend APIs (Optional) ---
NEWSAPI_KEY=
YOUTUBE_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Observability (Optional) ---
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT="friends-ai-production"
LANGCHAIN_API_KEY=
